# Server-side AI proxy — https://console.groq.com
GROQ_API_KEY=gsk_your_key

# Neon Postgres — both URLs from https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://user:password@ep-host-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-host.region.aws.neon.tech/dbname?sslmode=require

# Clerk — https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_after_clerk_setup

# EmailJS — https://www.emailjs.com → Dashboard (for email delivery + contact form)
# Service ID: Email Services tab · Public Key: Account → API Keys · Template IDs: Email Templates tab
VITE_EMAILJS_SERVICE_ID=service_xxx
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_EMAILJS_TEMPLATE_TRIP=template_xxx
VITE_EMAILJS_TEMPLATE_CONTACT=template_yyy
